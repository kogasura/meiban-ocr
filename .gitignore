# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
build/
dist/

# Node
node_modules/
.pnpm-store/
*.tsbuildinfo
.turbo/

# Vite / TypeScript build artifacts
packages/runtime/dist/

# npm pack output (`pnpm pack` で生成される tarball)
packages/runtime/*.tgz

# Auto-generated by scripts/bundle-model.mjs (raw ONNX, 3MB)
packages/runtime/src/assets/*.onnx

# Datasets (must not be committed) — repo root のみ anchor 必要
# (anchor しないと packages/trainer/src/.../data/ も巻き込む)
/videos/
/samples/
/data/
*.mp4
*.mov
*.avi

# Test set (隔離。Git LFS か別管理を検討)
/samples_test/*
!/samples_test/.gitkeep

# Fonts (Open Font Licenseのものをユーザーが配置)
/fonts/*
!/fonts/.gitkeep
!/fonts/README.md

# Models (Git LFS or HuggingFace Hub)
/models/*
!/models/.gitkeep

# Training runs (大型 checkpoint は除外、メタデータだけ commit)
runs/*/*.pt
runs/*/last.pt
runs/*/best.pt

# Misc
.DS_Store
*.log
.env
.env.local
.idea/
.vscode/
!.vscode/settings.example.json
